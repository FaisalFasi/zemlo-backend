{
  "name": "zemlo-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "overrides": {
    "lodash": "^4.17.22"
  },
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "prisma generate --schema=prisma/schema",
    "build": "nest build",
    "start": "nest start src/main",
    "start:dev": "nest start src/main --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.{ts,cjs}\"",
    "lint": "eslint \"{src,apps,libs,test,scripts}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test,scripts}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "inventory:release-expired": "tsx scripts/release-expired-inventory-reservations.ts",
    "check:api-contract": "node scripts/audit-api-contracts.cjs",
    "check:dto-contract": "tsx scripts/audit-dto-contract.ts",
    "check:inventory": "tsx scripts/audit-inventory-lifecycle.ts",
    "check:openapi": "tsx scripts/audit-openapi-quality.ts",
    "check:rbac": "tsx scripts/audit-rbac.ts",
    "check:swagger-dto": "node scripts/audit-swagger-dtos.cjs",
    "fix:swagger-dto": "node scripts/fix-swagger-dto-types.cjs",
    "check:quick": "npm run lint && npm run build",
    "check:full": "npm run check:quick && npm run check:rbac && npm run check:dto-contract && npm run check:swagger-dto && npm run check:api-contract && npm run openapi:export && npm run check:openapi && npm run check:inventory",
    "verify": "npm run check:full"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "7.3.0",
    "@prisma/client": "7.3.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.17.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "glob": "^13.0.6",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "7.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
