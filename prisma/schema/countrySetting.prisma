model CountrySetting {
  id String @id @default(uuid())

  name String
  iso2 String  @unique
  iso3 String? @unique

  currency  String?
  phoneCode String?

  isActive           Boolean @default(true)
  allowWebsiteAccess Boolean @default(true)
  allowCheckout      Boolean @default(true)
  allowShipping      Boolean @default(true)

  isDefault Boolean @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([iso2])
  @@index([isActive])
  @@index([allowWebsiteAccess])
  @@index([allowCheckout])
  @@index([allowShipping])
  @@map("country_settings")
}
