// ============================================
// PLATFORM SETTINGS (Admin Control Panel)
// ============================================

model PlatformSettings {
    id String @id @default(uuid())

    storeName    String  @default("My E-Commerce Store")
    storeEmail   String  @default("support@example.com")
    supportPhone String?

    allowGuestCheckout Boolean @default(true)

    requireEmailVerification Boolean @default(false)

    enableReviews  Boolean @default(true)
    enableWishlist Boolean @default(true)
    enableChat     Boolean @default(false)

    updatedAt DateTime @updatedAt
    updatedBy String? // Admin user ID who changed settings

    @@map("platform_settings")
}
