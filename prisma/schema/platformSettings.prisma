model PlatformSettings {
  id String @id @default("default")

  storeName       String  @default("Zemlo")
  storeEmail      String  @default("support@zemlo.com")
  supportPhone    String?
  supportWhatsapp String?
  storeLogoUrl    String?
  storeFaviconUrl String?

  businessName    String?
  businessAddress String?
  businessCity    String?
  businessState   String?
  businessZipCode String?
  businessCountry String? @default("US")

  currency            String   @default("USD")
  taxRate             Decimal  @default(0) @db.Decimal(5, 2)
  freeShippingOver    Decimal? @db.Decimal(10, 2)
  defaultShippingCost Decimal  @default(0) @db.Decimal(10, 2)

  allowGuestCheckout       Boolean @default(true)
  requireEmailVerification Boolean @default(false)
  allowAccountRegistration Boolean @default(true)

  enableReviews   Boolean @default(false)
  enableWishlist  Boolean @default(false)
  enableCoupons   Boolean @default(false)
  enableChat      Boolean @default(false)
  maintenanceMode Boolean @default(false)

  homepageTitle       String? @default("Zemlo")
  homepageDescription String? @db.Text
  announcementText    String?
  announcementEnabled Boolean @default(false)

  instagramUrl String?
  facebookUrl  String?
  tiktokUrl    String?
  youtubeUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}
