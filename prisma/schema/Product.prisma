// ============================================
// PRODUCT MODELS (Advanced)
// ============================================

model Category {
    id          String  @id @default(uuid())
    name        String  @unique
    slug        String  @unique
    description String? @db.Text
    image       String?
    icon        String?
    isActive    Boolean @default(true)

    // Nested categories
    parentId String?
    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children Category[] @relation("CategoryHierarchy")

    // SEO
    metaTitle       String?
    metaDescription String? @db.Text

    position Int @default(0) // For ordering

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    products   Product[]
    attributes CategoryAttribute[]

    @@index([slug])
    @@index([parentId])
    @@map("categories")
}

// Flexible attributes per category (e.g., Electronics: Screen Size, RAM)
model CategoryAttribute {
    id           String        @id @default(uuid())
    name         String // "Screen Size", "RAM", "Material"
    type         AttributeType // TEXT, NUMBER, SELECT, MULTI_SELECT
    isRequired   Boolean       @default(false)
    isFilterable Boolean       @default(true) // Can filter by this on frontend

    categoryId String
    category   Category @relation(fields: [categoryId], references: [id])

    // For SELECT types
    options String[] // ["Small", "Medium", "Large"]

    productAttributes ProductAttribute[]

    @@index([categoryId])
    @@map("category_attributes")
}

enum AttributeType {
    TEXT
    NUMBER
    SELECT
    MULTI_SELECT
    COLOR
}

model Product {
    id               String  @id @default(uuid())
    name             String
    slug             String  @unique
    description      String? @db.Text
    shortDescription String? @db.Text

    // Base price (variants can override)
    basePrice      Decimal  @db.Decimal(10, 2)
    compareAtPrice Decimal? @db.Decimal(10, 2) // Original price for discounts
    costPrice      Decimal? @db.Decimal(10, 2) // For profit calculation

    // SEO
    metaTitle       String?
    metaDescription String?  @db.Text
    keywords        String[]

    // Status
    status     ProductStatus @default(DRAFT)
    isActive   Boolean       @default(true)
    isFeatured Boolean       @default(false)

    // Metrics
    views         Int     @default(0)
    totalSales    Int     @default(0)
    averageRating Decimal @default(0) @db.Decimal(3, 2)
    reviewCount   Int     @default(0)

    // Category & Seller
    categoryId String
    category   Category @relation(fields: [categoryId], references: [id])

    sellerId String
    seller   SellerProfile @relation(fields: [sellerId], references: [id])

    // Shipping
    weight Decimal? @db.Decimal(8, 2) // kg
    length Decimal? @db.Decimal(8, 2) // cm
    width  Decimal? @db.Decimal(8, 2)
    height Decimal? @db.Decimal(8, 2)

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    publishedAt DateTime?

    // Relations
    images        ProductImage[]
    variants      ProductVariant[]
    attributes    ProductAttribute[]
    inventory     Inventory[]
    reviews       Review[]
    questions     ProductQuestion[]
    orderItems    OrderItem[]
    cartItems     CartItem[]
    wishlistItems WishlistItem[]
    viewHistory   ViewHistory[]

    @@index([slug])
    @@index([categoryId])
    @@index([sellerId])
    @@index([status])
    @@index([isFeatured])
    @@map("products")
}

enum ProductStatus {
    DRAFT
    ACTIVE
    INACTIVE
    OUT_OF_STOCK
    DISCONTINUED
}

model ProductImage {
    id        String  @id @default(uuid())
    url       String
    altText   String?
    position  Int     @default(0)
    isDefault Boolean @default(false)

    productId String
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@index([productId])
    @@map("product_images")
}

// Product attributes (specific values for this product)
model ProductAttribute {
    id    String @id @default(uuid())
    value String // "14 inches", "16GB", "Cotton"

    productId String
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    attributeId String
    attribute   CategoryAttribute @relation(fields: [attributeId], references: [id])

    @@index([productId])
    @@map("product_attributes")
}

// Product Variants (e.g., Red-Small, Blue-Medium)
model ProductVariant {
    id   String @id @default(uuid())
    sku  String @unique
    name String // "Red - Small"

    // Override base price if needed
    price          Decimal? @db.Decimal(10, 2)
    compareAtPrice Decimal? @db.Decimal(10, 2)

    // Variant options
    options Json // {"color": "Red", "size": "Small"}

    image    String?
    isActive Boolean @default(true)

    productId String
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    inventory  Inventory[]
    orderItems OrderItem[]
    cartItems  CartItem[]

    @@index([productId])
    @@index([sku])
    @@map("product_variants")
}
